  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/node": "22.19.11",
    "dotenv": "17.3.1",
    "drizzle-kit": "0.31.9",
