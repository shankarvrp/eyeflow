{
  "extends": "../../tsconfig.base.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": { "#/*": ["./src/*"], "@/*": ["./src/*"] },
    "types": ["vite/client", "vitest/globals", "node"]
  }
}
